{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    // No real build exists for this package yet — execution happens
    // through tsx (see apps/api's dev script). This config exists purely
    // for accurate type-checking and editor support right now.
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
